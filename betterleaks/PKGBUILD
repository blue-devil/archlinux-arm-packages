# Contributor: Daniel M. Capella <polycitizen@gmail.com>
# Contributor: Blue DeviL // SCT <bluedevil.SCT at proton dot me>

pkgname=betterleaks
pkgver=1.1.2
pkgrel=1
pkgdesc='A Better Secrets Scanner built for configurability and speed'
url=https://github.com/betterleaks/betterleaks
arch=('x86_64' 'i686' 'aarch64')
replaces=('betterleaks-bin')
license=('MIT')
depends=('glibc')
makedepends=('go')
checkdepends=('git')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('16b155bfe1b9109d6c3d368c66a1748b9f0d9ad7ea95ec8cc285f6267aaa0835')

build() {
  cd "${pkgname}-$pkgver"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"
  go build -ldflags "-X=github.com/betterleaks/betterleaks/v8/cmd.Version=${pkgver}" .
}

check() {
  cd "${pkgname}-$pkgver"
  go test -v ./... .
}

package() {
  cd "${pkgname}-$pkgver"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  ./gitleaks completion bash --no-descriptions |
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/bash-completion/completions/${pkgname}"
  ./gitleaks completion zsh --no-descriptions |
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/zsh/site-functions/_${pkgname}"
  ./gitleaks completion fish --no-descriptions |
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/fish/vendor_completions.d/${pkgname}.fish"
}

