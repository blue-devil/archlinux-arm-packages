# Maintainer: Blue DeviL // SCT <bluedevil.SCT@gmail.com>

pkgbase=keystone-engine-git
pkgname=('keystone-git' 'python-keystone-git')
_pkgname=keystone-engine
pkgver=0.9.2.r38.gfb92f32
pkgrel=1
pkgdesc="Lightweight multi-platform, multi-architecture assembler framework"
arch=('x86_64' 'aarch64')
url="https://github.com/keystone-engine/keystone"
license=('GPL-2.0')
depends=('glibc')
makedepends=('git' 'cmake' 'python' 'perl')
source=(
  "${_pkgname}::git+https://github.com/keystone-engine/keystone"
  "sct-keystone-cmake-fixes.patch"
)
sha256sums=(
  'SKIP'
  'bafcf6b418b156eab91232b8464bf4ee1c29704f46aa20565a585c2f68d0a1fd'
)

pkgver() {
  cd "${srcdir}/${_pkgname}"
  git describe --always --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${srcdir}/${_pkgname}"
  patch -Np1 -i "${srcdir}/sct-keystone-cmake-fixes.patch"
}

build() {
  cd "${srcdir}/${_pkgname}"

  local warn_flags="\
  -Wno-implicit-fallthrough \
  -Wno-deprecated-declarations \
  -Wno-unused-but-set-parameter \
  -Wno-misleading-indentation \
  -Wno-array-bounds \
  -Wno-switch \
  -Wno-format-truncation"

  cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    -DCMAKE_POLICY_DEFAULT_CMP0051=NEW \
    -DCMAKE_POLICY_DEFAULT_CMP0048=NEW \
    -DPYTHON_EXECUTABLE=/usr/bin/python \
    -DPERL_EXECUTABLE=/usr/bin/perl \
    -DCMAKE_C_FLAGS="$CFLAGS $warn_flags" \
    -DCMAKE_CXX_FLAGS="$CXXFLAGS $warn_flags -std=c++14" \
    -DBUILD_LIBS_ONLY=OFF \
    -DLLVM_BUILD_32_BITS=OFF \
    -DCMAKE_BUILD_TYPE=None \
    -DBUILD_SHARED_LIBS=ON \
    -DLLVM_TARGETS_TO_BUILD=all
  cmake --build build

  (
    cd bindings/python
    python setup.py build
  )
}

package_keystone-git() {
  depends=('glibc' 'gcc-libs')
  provides=('keystone' 'libkeystone.so')
  conflicts=('keystone')

  cd "${srcdir}/${_pkgname}"
  DESTDIR="${pkgdir}" cmake --install build
  install -d "${pkgdir}/usr/share/doc/${pkgname}"
  cp -r samples "${pkgdir}/usr/share/doc/${pkgname}/"
  install -Dm 644 LICENSE-COM.TXT "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-COM.TXT"
}

package_python-keystone-git() {
  depends=('python' 'keystone-git')
  license=('BSD')
  provides=('python-keystone')
  conflicts=('python-keystone')

  cd "${srcdir}/${_pkgname}/bindings/python"
  python setup.py install --root="${pkgdir}" -O1 --skip-build
  install -Dm 755 sample.py -t "${pkgdir}/usr/share/doc/${pkgname}"
  install -Dm 644 LICENSE.TXT -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

